# Public site
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel Production (obligatorio para WhatsApp / Open Graph):
# NEXT_PUBLIC_SITE_URL=https://autointegral.mx
NEXT_PUBLIC_WHATSAPP_NUMBER=525514745677

# Supabase (same names locally and on Vercel Production/Preview)
# Local: values from `npx supabase status`
# Remote: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-after-supabase-start

# Server/ops only — never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=replace-after-supabase-start-server-only

# Cloudinary (Phase 0+)
# Cloud name may be public; API key/secret are server-only.
# Do not expose API key or API secret with a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret-server-only
